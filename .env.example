# =============================================================================
# 多 API 配置（推荐 — 启用轮询模式）
# =============================================================================
# 使用带序号的变量定义多组 API：API_1_*、API_2_*、API_3_*……
# 每次请求按顺序轮流使用所有 API。
# 若某组 API 重试全部失败，自动切换到下一组。

API_1_KEY=your_api_key_here
API_1_BASE_URL=https://api.openai.com/v1
API_1_MODEL=gpt-4o-mini
# API_1_DISABLE_PROXY=true

API_2_KEY=your_second_api_key_here
API_2_BASE_URL=https://api.openai.com/v1
API_2_MODEL=gpt-4o-mini
# API_2_DISABLE_PROXY=true

# API_3_KEY=your_third_api_key_here
# API_3_BASE_URL=https://your-local-api/v1
# API_3_MODEL=llama3

# =============================================================================
# 单 API 配置（兼容旧版）
# =============================================================================
# 未设置 API_N_KEY 时自动使用此配置。

# OPENAI_API_KEY=your_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# 共享设置
# =============================================================================

# 翻译目标语言
TARGET_LANGUAGE=Chinese

# 默认模型（当 API_N_MODEL 未设置时使用）
MODEL_NAME=gpt-4o-mini

# 性能参数
BATCH_SIZE=30          # 每次 API 调用翻译的字幕条数
REQUEST_INTERVAL=1.0   # 请求间隔（秒），防止触发限流
CONTEXT_WINDOW=5       # 增强上下文模式的滑动窗口大小

# 代理设置（本地 API 建议设为 true，远程 API 按需调整）
DISABLE_PROXY=true

# =============================================================================
# 进阶翻译与 NLP 设置
# =============================================================================

# 二次润色模式：单条失败或正常返回后，多发送一次以修正语段的请求
# REFINE_PASS=false

# 长度约束 / 阅读速度控制：单行最大字符数，控制大模型输出时的长度
# MAX_LENGTH=40

# 智能断行：如果句子过长，在自然语言停顿处自动插入 [BR] 断行
# SMART_BREAK=true

# 标点本地化：是否将英文半角标点翻译后替换为中文全角标点
# PUNCT_LOCALIZE=true

# 翻译结果缓存：根据原文计算 MD5，再次遇到完全相同的源文本直接从本地读取，节约成本
# ENABLE_CACHE=true
