# =============================================================================
# Multi-API Configuration (Recommended — enables round-robin polling)
# =============================================================================
# Define multiple APIs using indexed variables: API_1_*, API_2_*, API_3_*, ...
# Requests are distributed across all configured APIs in round-robin order.
# If one API fails all retries, the next API is tried automatically.

API_1_KEY=your_api_key_here
API_1_BASE_URL=https://api.openai.com/v1
API_1_MODEL=gpt-4o-mini
# API_1_DISABLE_PROXY=true

API_2_KEY=your_second_api_key_here
API_2_BASE_URL=https://api.openai.com/v1
API_2_MODEL=gpt-4o-mini
# API_2_DISABLE_PROXY=true

# API_3_KEY=your_third_api_key_here
# API_3_BASE_URL=https://your-local-api/v1
# API_3_MODEL=llama3

# =============================================================================
# Single-API Configuration (Legacy / fallback)
# =============================================================================
# Used when no API_N_KEY variables are set.

# OPENAI_API_KEY=your_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# Shared Settings
# =============================================================================

# Translation target language
TARGET_LANGUAGE=Chinese

# Default model (used as fallback when API_N_MODEL is not set)
MODEL_NAME=gpt-4o-mini

# Performance
BATCH_SIZE=30
REQUEST_INTERVAL=1.0
CONTEXT_WINDOW=5

# Proxy (set to false if you need a proxy for remote APIs)
DISABLE_PROXY=true
